{
	"compatibility_date": "2025-10-08",
	"main": "src/index.ts",
	"name": "file-fetch-tool",
	"upload_source_maps": true,
	"observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  },
  "r2_buckets": [
    {
      "binding": "file-bucket",
      "bucket_name": "file-fetch-tool"
    }
  ],
  "kv_namespaces": [
    {
      "id": "a812f7e5fb2d4ca383cd17637fca4289",
      "binding": "file-index"
    }
  ]
}
